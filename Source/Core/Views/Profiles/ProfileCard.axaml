<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:avalonia="clr-namespace:FluentIcons.Avalonia;assembly=FluentIcons.Avalonia"
    xmlns:controls="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
    xmlns:controls1="clr-namespace:Core.Controls"
    xmlns:profiles="clr-namespace:Core.ViewModels.Profiles"
    xmlns:profilesControls="clr-namespace:Core.Controls.Profiles"
    xmlns:profilesViews="clr-namespace:Core.Views.Profiles"
    xmlns:framework="clr-namespace:Core.Services.Framework"
    xmlns:fluent="clr-namespace:FluentIcons.Avalonia.Fluent;assembly=FluentIcons.Avalonia.Fluent"

    x:Class="Core.Views.Profiles.ProfileCard"
    x:DataType="profiles:ProfileCardViewModel"
    
    PointerEntered="OnCardPointerEntered"
    PointerExited="OnCardPointerExited"
    IsHitTestVisible="True"
    mc:Ignorable="d"
    d:DesignWidth="500"
    Background="Transparent"
    ClipToBounds="False"
    d:DesignHeight="280">
    
    <Grid>
        <!-- Scale entire card -->
        <Grid.RenderTransform>
            <ScaleTransform ScaleX="{Binding Scale}" ScaleY="{Binding Scale}"/>
        </Grid.RenderTransform>
        
        <!-- Card -->
        <Border 
            CornerRadius="15"
            x:Name="ProfileCardBackground"
            Background="#B3131314"
            ClipToBounds="True"
            BorderBrush="#232526"
            BorderThickness="01"
            Margin="14 6 14 28"
            HorizontalAlignment="Stretch" 
            VerticalAlignment="Center"
            MinWidth="400"
            Height="225">
            
            <Grid Background="Transparent">
                <!-- Glow Brush when Profile is loading -->
                <Border
                  Opacity="{Binding Source={x:Static framework:AppServices.MainWM}, Path=TitleBarOpacity}"
                  IsVisible="{Binding IsRunning}"
                  Background="{Binding Profile.Display.GradientBrush}"
                  Margin="45 -100 0 0"
                  Width="50"
                  Height="50"
                  HorizontalAlignment="Left">
                    <Border.Effect>
                        <BlurEffect Radius="50"/>
                    </Border.Effect>
                </Border>
                
                <!-- Cursor Effect -->
                <controls1:CursorEffectControl/>
                
                <Grid RowDefinitions="Auto,*,Auto">
                  <!-- Content -->
                  <Grid Grid.Row="1" Margin="30,31,16,12" RowDefinitions="Auto,*">
                    <!-- Header -->
                    <Grid ColumnDefinitions="Auto,*,Auto">

                      <Grid>
                        <!-- Splash -->
                        <profilesControls:ProfileSplashControl
                          SplashScale="2.45"
                          Radius="20"
                          DataContext="{Binding Profile}">
                          <profilesControls:ProfileSplashControl.RenderTransform>
                            <ScaleTransform
                              ScaleX="{Binding ScaledMoreUp, RelativeSource={RelativeSource AncestorType={x:Type profilesViews:ProfileCard}}}"
                              ScaleY="{Binding ScaledMoreUp, RelativeSource={RelativeSource AncestorType={x:Type profilesViews:ProfileCard}}}" />
                          </profilesControls:ProfileSplashControl.RenderTransform>
                        </profilesControls:ProfileSplashControl>
                      </Grid>
                      
                      <!-- Profile Info -->
                      <StackPanel Grid.Column="1"
                                  Margin="17 0 0 0"
                                  VerticalAlignment="Center"
                                  Spacing="7">

                        <!-- Name Row -->
                        <Grid ColumnDefinitions="Auto,Auto,Auto">
                          <TextBlock
                            Text="{Binding Profile.Name}"
                            FontSize="27"
                            FontWeight="Bold"
                            MaxWidth="220"
                            TextTrimming="CharacterEllipsis"/>

                          <Border Grid.Column="1"
                                  IsVisible="{Binding Profile.IsAutoDetected}"
                                  ToolTip.Tip="Auto-detected"
                                  Padding="4"
                                  Width="24"
                                  Height="24"
                                  Background="#0095ff"
                                  CornerRadius="8"
                                  Margin="8 0 0 0">
                            <avalonia:FluentIcon
                              Icon="Communication"
                              FontSize="20"/>
                          </Border>

                          <avalonia:FluentIcon
                            Grid.Column="2"
                            IsVisible="{Binding Profile.HasValidationErrors}"
                            Icon="Warning"
                            Foreground="Red"
                            Margin="8 0 0 0"
                            ToolTip.Tip="Profile has errors"/>
                        </Grid>

                        <!-- Directory -->
                        <Grid ColumnDefinitions="Auto,*"
                              Opacity="0.55"
                              Margin="0 0 0 0">

                          <controls:SymbolIcon
                            Height="20"
                            Symbol="Folder"
                            FontSize="20"
                            Width="20" />

                          <TextBlock
                            Grid.Column="1"
                            Text="{Binding Profile.ArchiveDirectory}"
                            FontSize="13"
                            Margin="5 0 0 0"
                            TextTrimming="CharacterEllipsis"
                            HorizontalAlignment="Left"
                            MaxWidth="{Binding DirectoryMaxWidth}"
                            VerticalAlignment="Center"/>
                        </Grid>
                      </StackPanel>

                      <!-- More Options -->
                      <Button Grid.Column="2"
                              x:Name="MoreOptionsButton"
                              Classes="HoverLift"
                              Width="32"
                              Height="32"
                              Margin="0 0 0 30"
                              CornerRadius="10"
                              Background="Transparent"
                              Focusable="False">

                        <Button.Flyout>
                            <Flyout>
                                <StackPanel Width="150" Spacing="2">
                                    <Button Classes="SoftHoverLift" Click="EditButton_Click" Cursor="Hand" HorizontalAlignment="Stretch" Padding="10 0" Height="40" Background="Transparent" CornerRadius="7" HorizontalContentAlignment="Left" VerticalContentAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <controls:SymbolIcon
                                              Height="18"
                                              Symbol="Settings"
                                              Foreground="White"
                                              FontSize="20"
                                              Width="18" />
                                            
                                            <TextBlock FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                Settings
                                            </TextBlock>
                                        </StackPanel>
                                    </Button>
                                  
                                    <StackPanel HorizontalAlignment="Stretch" IsVisible="{Binding !Profile.IsAutoDetected}" Orientation="Vertical">
                                      <Button Classes="SoftHoverLift" HorizontalAlignment="Stretch"
                                              Padding="10 0"
                                              Height="40"
                                              CornerRadius="7"
                                              Cursor="Hand"
                                              IsVisible="{Binding !Profile.IsAutoDetected}"
                                              Click="DeleteProfile"
                                              Background="Transparent"
                                              HorizontalContentAlignment="Left"
                                              VerticalContentAlignment="Center">
                                        <Button.Resources>
                                          <ResourceDictionary>
                                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#661111"/>
                                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#661111"/>
                                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#ffdddd"/>
                                            <SolidColorBrush x:Key="ButtonForeground" Color="#ff4f64"/>
                                          </ResourceDictionary>
                                        </Button.Resources>

                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                          <controls:SymbolIcon
                                            Height="18"
                                            Symbol="Delete"
                                            FontSize="20"
                                            Width="18" />

                                          <TextBlock FontWeight="Medium"
                                                     FontSize="15"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     Foreground="{DynamicResource ButtonForeground}">
                                            Delete
                                          </TextBlock>
                                        </StackPanel>
                                      </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Flyout>
                          </Button.Flyout>
                        
                        <controls:SymbolIcon
                          Height="25"
                          Symbol="More"
                          FontSize="25"
                          Width="25" />
                      </Button>
                    </Grid>
                    
                    <!-- Last Used -->
                    <TextBlock
                      Grid.Row="1"
                      Margin="0,15,0,0"
                      Text="{Binding LastUsed}"
                      FontSize="15"
                      FontWeight="Medium"
                      Foreground="{DynamicResource ProfileCardLastUsedForeground}"/>
                  </Grid>
                </Grid>
                
                <Grid VerticalAlignment="Bottom" ColumnDefinitions="*,10,50" Margin="25,0,25,25">
                  <Grid Grid.Column="0" IsEnabled="{Binding !Profile.HasValidationErrors}">
                    <Button
                      x:Name="StartButton"
                      Foreground="White"
                      IsEnabled="{Binding !IsRunning}"
                      Height="50"
                      Opacity="0.95"
                      Classes="PressScale HoverLift"
                      Cursor="Hand"
                      ClipToBounds="True"
                      BorderThickness="0"
                      Click="StartButton_Click"
                      CornerRadius="8"
                      HorizontalAlignment="Stretch">
                      
                      <Button.Background>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                          <GradientStop Color="#1f66ff" Offset="0.95"/>
                        </LinearGradientBrush>
                      </Button.Background>
                      
                      <Button.Resources>
                        <ResourceDictionary>
                          <LinearGradientBrush x:Key="ButtonBackgroundPointerOver" StartPoint="0%,0%" EndPoint="100%,0%">
                            <GradientStop Color="#1f66ff" Offset="0.95"/>
                          </LinearGradientBrush>
                          
                          <LinearGradientBrush x:Key="ButtonBackgroundPressed" StartPoint="0%,0%" EndPoint="100%,0%">
                            <GradientStop Color="#1248CC" Offset="0.05"/>
                          </LinearGradientBrush>

                          <LinearGradientBrush x:Key="ButtonBackgroundDisabled" StartPoint="0%,0%" EndPoint="100%,0%">
                            <GradientStop Color="#802E2D2B" Offset="0.9"/>
                          </LinearGradientBrush>
                          
                          <SolidColorBrush x:Key="ButtonForegroundPointerOver">White</SolidColorBrush>
                          <SolidColorBrush x:Key="ButtonForegroundPressed">White</SolidColorBrush>
                        </ResourceDictionary>
                      </Button.Resources>
                      
                      <Grid>
                        <Grid IsVisible="{Binding !Profile.HasValidationErrors}">
                          <Border
                            Background="White"
                            Height="1.4"
                            Opacity="0.1"
                            CornerRadius="16 16 0 0"
                            Margin="0 -5 0 0"
                            VerticalAlignment="Top"
                            IsVisible="{Binding !IsRunning}"
                            HorizontalAlignment="Stretch"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                          <controls:SymbolIcon
                            Symbol="Play"
                            HorizontalAlignment="Center"
                            Margin="0 0 3 0"
                            VerticalAlignment="Center"
                            FontSize="25"/>
                          <TextBlock
                            FontWeight="Medium"
                            VerticalAlignment="Center"
                            Margin="0 1 0 0" Text="{Binding LoadButtonText}" FontSize="16" HorizontalAlignment="Center"/>
                        </StackPanel>
                      </Grid>
                    </Button>
                  </Grid>
                  
                  <!-- Edit Button -->
                  <Button
                    x:Name="EditButton"
                    Grid.Column="2"
                    Foreground="#e0e0e0"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="1"
                    CornerRadius="15"
                    Cursor="Hand"
                    Height="50"
                    Classes="PressScale HoverLift"
                    Focusable="False"
                    Click="EditButton_Click"
                    HorizontalAlignment="Stretch">
                    <Button.Resources>
                      <ResourceDictionary>
                        <SolidColorBrush x:Key="ButtonBackgroundPressed">#1c1c1c</SolidColorBrush>
                        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver">#b3b3b3</SolidColorBrush>
                        <SolidColorBrush x:Key="ButtonBorderBrushPressed">#b3b3b3</SolidColorBrush>
                      </ResourceDictionary>
                    </Button.Resources>
                    
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                      <fluent:FluentIcon
                        Icon="PersonEdit"
                        IconSize="Size32"
                        IconVariant="Regular"/>
                    </StackPanel>
                  </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
